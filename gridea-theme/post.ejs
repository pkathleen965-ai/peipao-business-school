<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post.title %> - <%= site.title %></title>
    <link rel="stylesheet" href="<%= themeRouter %>/css/style.css">
</head>
<body>
    <!-- 导航栏 -->
    <header>
        <div class="container nav-container">
            <div class="logo">
                <a href="<%= themeRouter %>/">
                    <span class="logo-dot"></span>
                    <span class="logo-text"><%= site.logoText || '陪跑者' %></span>
                </a>
            </div>
            <nav class="nav-menu">
                <ul>
                    <li><a href="<%= themeRouter %>/">首页</a></li>
                    <li><a href="<%= themeRouter %>/about.html">关于我们</a></li>
                    <li><a href="<%= themeRouter %>/tools.html">工具介绍</a></li>
                    <li><a href="<%= themeRouter %>/service.html">陪伴方式</a></li>
                    <li><a href="<%= themeRouter %>/start.html">开始陪跑</a></li>
                    <li><a href="<%= themeRouter %>/notes/">知识陪伴</a></li>
                </ul>
            </nav>
            <a href="<%= themeRouter %>/start.html" class="cta-btn outline">预约诊断</a>
            <button class="nav-toggle" aria-label="切换导航菜单">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </header>

    <!-- 文章内容 -->
    <main>
        <article class="article-container">
            <div class="container">
                <div class="article-header">
                    <span class="article-tag"><%= post.category || '老板闭门笔记' %></span>
                    <h1><%= post.title %></h1>
                    <p class="article-date"><%= post.created %></p>
                </div>
                
                <div class="article-content">
                    <%- post.content %>
                </div>
                
                <div class="article-footer">
                    <a href="<%= themeRouter %>/notes/" class="cta-link">← 返回知识陪伴</a>
                </div>
            </div>
        </article>
    </main>

    <!-- 底部 -->
    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-logo">
                    <span class="logo-dot"></span>
                    <span class="logo-text"><%= site.logoText || '陪跑者' %></span>
                </div>
                <div class="footer-links">
                    <a href="<%= themeRouter %>/">首页</a>
                    <a href="<%= themeRouter %>/about.html">关于我们</a>
                    <a href="<%= themeRouter %>/tools.html">工具介绍</a>
                    <a href="<%= themeRouter %>/service.html">陪伴方式</a>
                    <a href="<%= themeRouter %>/start.html">开始陪跑</a>
                    <a href="<%= themeRouter %>/notes/">知识陪伴</a>
                </div>
                <div class="footer-contact">
                    <div class="wechat-qr">
                        <div class="qr-placeholder">微信二维码</div>
                    </div>
                    <p>微信号：<%= site.wechat || 'peipaozhe2025' %></p>
                </div>
                <div class="footer-info">
                    <p>© <%= site.year || '2026' %> <%= site.logoText || '陪跑者' %>  |  <%= site.icpNo || '蜀ICP备xxxxx号' %></p>
                </div>
            </div>
            <div class="footer-bottom"></div>
        </div>
    </footer>

    <script src="<%= themeRouter %>/js/main.js"></script>
</body>
</html>